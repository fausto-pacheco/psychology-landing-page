    </div>
    <div class="contact-location">
      📍 Ciudad Valles, San Luis Potosí &nbsp;·&nbsp; Atención online disponible para todo México
    </div>
  </div>
</section>

<style>
  #contact {
    background: var(--charcoal);
    color: var(--cream);
    text-align: center;
    padding-block: calc(var(--gap) * 1.5);
  }
  #contact .label { color: var(--sand); }
  #contact h2 { font-size: clamp(2.2rem, 4.5vw, 4rem); color: var(--offwhite); margin-block: 1rem 1.25rem; }
  #contact p { font-size: .92rem; color: var(--sand); max-width: 460px; margin-inline: auto; line-height: 1.75; margin-bottom: 2.5rem; }

  .contact-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn-ig {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    padding: .85rem 2rem;
    background: transparent;
    color: var(--cream);
    border: 1px solid rgba(255,255,255,.25);
    font-size: .8rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    font-family: 'Jost', sans-serif;
    border-radius: var(--r);
    transition: border-color .2s, background .2s;
  }
  .btn-ig:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.05); }

  .contact-location {
    margin-top: 3rem;
    font-size: .75rem;
    letter-spacing: .1em;
    color: var(--sand);
    text-transform: uppercase;
  }
</style>
